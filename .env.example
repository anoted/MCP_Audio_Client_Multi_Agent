# ---------------------------------------------------------------------------
# Text LLM — any OpenAI-compatible endpoint (required)
# e.g. https://api.openai.com/v1, https://integrate.api.nvidia.com/v1,
#      http://localhost:11434/v1 (Ollama), vLLM, etc.
# ---------------------------------------------------------------------------
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=google/diffusiongemma-26b-a4b-it
LLM_TEMPERATURE=0.7
# SYSTEM_PROMPT=You are a helpful voice assistant.

# Folder for saved conversations (one JSON file each)
# CONVERSATIONS_DIR=conversations

# ---------------------------------------------------------------------------
# NVIDIA NIM speech services (Riva gRPC — not OpenAI-compatible, by design)
# Get an API key at https://build.nvidia.com (starts with nvapi-)
# ---------------------------------------------------------------------------
NVIDIA_API_KEY=your-api-key

# --- Speech-to-text: Parakeet CTC 1.1B ASR NIM (hosted) ---
# Function ID from https://build.nvidia.com/nvidia/parakeet-ctc-1_1b-asr
RIVA_ASR_SERVER=grpc.nvcf.nvidia.com:443
RIVA_ASR_FUNCTION_ID=1598d209-5e27-4d3c-8079-4751568b1081
ASR_LANGUAGE=en-US

# --- Text-to-speech: Magpie TTS Multilingual NIM (hosted) ---
# Function ID from https://build.nvidia.com/nvidia/magpie-tts-multilingual
RIVA_TTS_SERVER=grpc.nvcf.nvidia.com:443
RIVA_TTS_FUNCTION_ID=877104f7-e885-42b9-8de8-f6e4c6303969
TTS_VOICE=Magpie-Multilingual.EN-US.Aria
TTS_LANGUAGE=en-US
TTS_SAMPLE_RATE=22050

# For a locally deployed NIM container instead of the hosted API:
#   RIVA_ASR_SERVER=localhost:50051   (and leave RIVA_ASR_FUNCTION_ID empty)
#   RIVA_USE_SSL=false
# RIVA_USE_SSL=true

# ---------------------------------------------------------------------------
# MCP servers (see MCP_security.md)
# mcp_servers.json may reference environment variables as ${VAR} in url,
# headers, and env values — they are resolved from this file at connect time
# so secrets never live in the registry JSON.
# ---------------------------------------------------------------------------
# Bearer token for the Canvas MCP server's streamable HTTP endpoint.
# Must match CANVAS_MCP_AUTH_TOKEN in examples/Canvas_MCP/.env — generate one:
#   conda run -n mcpagents python examples/Canvas_MCP/canvas_mcp_server.py --make-token
CANVAS_MCP_AUTH_TOKEN=paste-the-generated-token-here

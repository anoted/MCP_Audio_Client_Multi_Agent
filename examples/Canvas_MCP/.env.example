# Copy this file to .env and fill in your values, then restart the server.

# Your institution's Canvas URL (no trailing slash)
CANVAS_BASE_URL=https://yourschool.instructure.com

# Personal access token: Canvas > Account > Settings > + New Access Token
CANVAS_API_TOKEN=your_token_here

# Where the MCP server listens (keep 127.0.0.1 — the endpoint has no auth)
MCP_HOST=127.0.0.1
MCP_PORT=8017

# Copy this file to .env and fill in your values, then restart the server.

# Your institution's Canvas URL (no trailing slash)
CANVAS_BASE_URL=https://yourschool.instructure.com

# Personal access token: Canvas > Account > Settings > + New Access Token
CANVAS_API_TOKEN=your_token_here

# Where the streamable HTTP endpoint listens (keep 127.0.0.1 unless you put
# the server behind an HTTPS reverse proxy — see MCP_security.md)
MCP_HOST=127.0.0.1
MCP_PORT=8017

# Bearer token HTTP clients must present (Authorization: Bearer <token>).
# Generate one:  python canvas_mcp_server.py --make-token
# The SAME value goes in the voice client's .env as CANVAS_MCP_AUTH_TOKEN so
# mcp_servers.json can send it. The server refuses to start over HTTP without
# it (CANVAS_MCP_ALLOW_NO_AUTH=1 overrides, for throwaway sandboxes only).
CANVAS_MCP_AUTH_TOKEN=paste-the-generated-token-here

# Extra allowed Host / Origin header values, comma-separated (localhost
# variants are always allowed; anything else is rejected with 403 as a
# DNS-rebinding defense)
# CANVAS_MCP_ALLOWED_HOSTS=
# CANVAS_MCP_ALLOWED_ORIGINS=

# Transport override: run over stdio instead of streamable HTTP
# MCP_TRANSPORT=stdio

# --- Client-side rate limiting (Canvas leaky-bucket protection) ---
# CANVAS_MAX_CONCURRENT=3      # max in-flight Canvas requests
# CANVAS_MIN_INTERVAL_MS=200   # spacing between request starts
# CANVAS_RATE_RETRIES=5        # backoff retries on 403 Rate Limit Exceeded
